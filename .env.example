# =============================================
# SCANGOO BACKEND — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/scangoo?retryWrites=true&w=majority

# JWT secret — use any long random string (e.g. run: openssl rand -hex 32)
JWT_SECRET=replace_with_a_long_random_secret_string

# JWT expiry (how long tokens stay valid)
JWT_EXPIRES_IN=7d

# Port (Render sets this automatically; keep 5000 for local dev)
PORT=5000

# Frontend URL (used for CORS — your Netlify URL or localhost for dev)
CLIENT_URL=http://localhost:3000
